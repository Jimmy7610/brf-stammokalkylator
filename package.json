{
  "name": "brf-stammokalkylator",
  "version": "1.0.0",
  "private": true,
  "description": "BRF Hjalpen for BRF-stammor on Cloudflare Workers",
  "scripts": {
    "prepare:cloudflare": "node scripts/prepare-cloudflare.mjs",
    "dev": "npm run prepare:cloudflare && wrangler dev",
    "deploy": "npm run prepare:cloudflare && wrangler deploy",
    "cf:deploy": "npm run prepare:cloudflare && wrangler deploy",
    "cf:d1:migrate": "wrangler d1 migrations apply brf-hjalpen",
    "cf:d1:migrate:local": "wrangler d1 migrations apply brf-hjalpen --local"
  },
  "devDependencies": {
    "wrangler": "^4.9.1"
  }
}
